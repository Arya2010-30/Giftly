rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isWeddingOwner(weddingId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/weddings/$(weddingId)).data.created_by == request.auth.uid;
    }
    
    function isWeddingMember(weddingId) {
      return isAuthenticated() && (
        isWeddingOwner(weddingId) || 
        exists(/databases/$(database)/documents/weddings/$(weddingId)/members/$(request.auth.uid))
      );
    }

    // Wedding rules
    match /weddings/{weddingId} {
      allow create: if isAuthenticated() && request.resource.data.created_by == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.created_by == request.auth.uid;
      
      // Gifts subcollection
      match /gifts/{giftId} {
        allow read, create, update, delete: if isWeddingMember(weddingId);
      }
      
      // Members subcollection
      match /members/{memberId} {
        allow read: if isWeddingMember(weddingId);
        allow create, update, delete: if isWeddingOwner(weddingId);
      }
    }
  }
}
